# =============================================================================
# Growth Advisor — ClearerThinking.org
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# ---------- Core LLM ----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=

# ---------- ClearerThinking site ----------
SITE_URL=https://www.clearerthinking.org
SITE_DOMAIN=clearerthinking.org

# ---------- Google APIs (Analytics 4, Search Console, Drive, Gmail, Calendar) ----------
# Path to a service account JSON, or use OAuth client below
GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json
GA4_PROPERTY_ID=
GSC_SITE_URL=https://www.clearerthinking.org/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ---------- Ahrefs ----------
AHREFS_API_KEY=

# ---------- beehiiv (newsletter) ----------
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ---------- Paid ads ----------
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

# ---------- Social ----------
X_BEARER_TOKEN=
LINKEDIN_ACCESS_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ---------- Product analytics ----------
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.posthog.com
MIXPANEL_PROJECT_TOKEN=
MIXPANEL_API_SECRET=
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# ---------- Revenue / payments ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- Ops / collaboration ----------
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=
NOTION_API_KEY=
NOTION_GROWTH_DB_ID=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
LINEAR_API_KEY=

# ---------- CMS (if applicable) ----------
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=

# ---------- Misc ----------
LOG_LEVEL=INFO
TIMEZONE=America/Sao_Paulo
